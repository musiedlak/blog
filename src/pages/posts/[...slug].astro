---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReasoningSeed from '../../components/ReasoningSeed.astro';
import authorPhoto from '../../assets/jan-musiedlak.jpeg';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = new Intl.DateTimeFormat('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const seed = post.data.reasoningSeed;
const sourceUrl = new URL(`posts/${post.id}/`, Astro.site).href;
---

<BaseLayout title={post.data.title} description={post.data.description} wide>
  {
    post.data.cover && (
      <figure class="post-hero">
        <Image
          src={post.data.cover}
          alt={post.data.coverAlt ?? ''}
          widths={[960, 1280, 1600]}
          sizes="100vw"
          loading="eager"
        />
      </figure>
    )
  }

  <article class="wrap post">
    <aside class="post-rail">
      <div class="post-rail-inner">
        <div class="post-meta">
          {post.data.kind && <span class="tag">{post.data.kind}</span>}
          <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
        </div>
      </div>
    </aside>

    <header class="post-header">
      <h1>{post.data.title}</h1>
      {post.data.subtitle && <p class="subtitle">{post.data.subtitle}</p>}
    </header>

    {
      post.data.tldr && post.data.tldr.length > 0 && (
        <aside class="tldr">
          <p class="tldr-label">Kurz gefasst</p>
          <ol class="keypoints">
            {post.data.tldr.map((point, i) => (
              <li>
                <span class="kp-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="kp-text">{point}</span>
              </li>
            ))}
          </ol>
        </aside>
      )
    }

    <div class="post-body">
      <Content />
    </div>

    {
      post.data.sources && post.data.sources.length > 0 && (
        <section class="post-appendix">
          <h2>Quellen</h2>
          <ul class="sources">
            {post.data.sources.map((s) => (
              <li>{s.url ? <a href={s.url} target="_blank" rel="noopener">{s.label}</a> : s.label}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      post.data.glossary && post.data.glossary.length > 0 && (
        <section class="post-appendix">
          <h2>Glossar</h2>
          <dl class="glossary">
            {post.data.glossary.map((g) => (
              <>
                <dt>{g.term}</dt>
                <dd>{g.definition}</dd>
              </>
            ))}
          </dl>
        </section>
      )
    }

    {
      seed && (
        <ReasoningSeed
          title={post.data.title}
          these={seed.these}
          frage={seed.frage}
          sourceUrl={sourceUrl}
        />
      )
    }

    <section class="author-bio">
      <Image src={authorPhoto} alt="Jan Musiedlak" width={96} height={96} class="author-photo" />
      <p>
        Jan Musiedlak begleitet Geschäftsführer produzierender Unternehmen dabei, strategische Fragen zu
        strukturieren, Prioritäten abzuleiten und implizite Annahmen explizit zu machen — bevor Ressourcen
        gebunden werden.
      </p>
    </section>

    <p class="back"><a href="/">← Alle Beiträge</a></p>
  </article>
</BaseLayout>

<script>
  // Nummerierte Insight-Überschriften der "Wesentliche Insights"-Sektion auszeichnen
  // (### N — Titel). Speist die Anzeige und den Reasoning-Seed-Copy-Button.
  const body = document.querySelector('.post-body');
  if (body) {
    body.querySelectorAll('h3').forEach((h3) => {
      const text = h3.textContent?.trim() || '';
      const match = text.match(/^(\d+)\s*—\s*(.+)$/);
      if (!match) return;
      const padded = String(parseInt(match[1], 10)).padStart(2, '0');
      h3.innerHTML = `<span class="fn-insight-num">${padded}</span> ${match[2]}`;
      h3.classList.add('fn-insight-heading');
      let sib = h3.nextElementSibling;
      while (sib && sib.tagName !== 'H2' && sib.tagName !== 'H3') {
        if (sib.tagName === 'P') sib.classList.add('fn-insight-p');
        sib = sib.nextElementSibling;
      }
    });
  }
</script>
