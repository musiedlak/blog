---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import authorPhoto from '../../assets/jan-musiedlak.jpeg';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = new Intl.DateTimeFormat('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const seed = post.data.reasoningSeed;
const seedText = seed
  ? `These: ${seed.these}\n\nZentrale Spannung: ${seed.frage}`
  : '';
---

<BaseLayout title={post.data.title} description={post.data.description} wide>
  {
    post.data.cover && (
      <figure class="post-hero">
        <Image
          src={post.data.cover}
          alt={post.data.coverAlt ?? ''}
          widths={[960, 1280, 1600]}
          sizes="100vw"
          loading="eager"
        />
      </figure>
    )
  }

  <article class="wrap post">
    <aside class="post-rail">
      <div class="post-rail-inner">
        <div class="post-meta">
          {post.data.kind && <span class="tag">{post.data.kind}</span>}
          <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
        </div>
      </div>
    </aside>

    <header class="post-header">
      <h1>{post.data.title}</h1>
      {post.data.subtitle && <p class="subtitle">{post.data.subtitle}</p>}
    </header>

    {
      post.data.tldr && post.data.tldr.length > 0 && (
        <aside class="tldr">
          <p class="tldr-label">Kurz gefasst</p>
          <ol class="keypoints">
            {post.data.tldr.map((point, i) => (
              <li>
                <span class="kp-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="kp-text">{point}</span>
              </li>
            ))}
          </ol>
        </aside>
      )
    }

    <div class="post-body">
      <Content />
    </div>

    {
      post.data.sources && post.data.sources.length > 0 && (
        <section class="post-appendix">
          <h2>Quellen</h2>
          <ul class="sources">
            {post.data.sources.map((s) => (
              <li>{s.url ? <a href={s.url} target="_blank" rel="noopener">{s.label}</a> : s.label}</li>
            ))}
          </ul>
        </section>
      )
    }

    {
      post.data.glossary && post.data.glossary.length > 0 && (
        <section class="post-appendix">
          <h2>Glossar</h2>
          <dl class="glossary">
            {post.data.glossary.map((g) => (
              <>
                <dt>{g.term}</dt>
                <dd>{g.definition}</dd>
              </>
            ))}
          </dl>
        </section>
      )
    }

    {
      seed && (
        <section class="post-appendix seed">
          <h2>Weiterdenken</h2>
          <p class="seed-intro">Kopiere diesen Impuls in dein KI-Tool und denk die Frage weiter.</p>
          <div class="seed-box">
            <pre class="seed-prompt">{seedText}</pre>
            <button class="seed-copy" type="button" data-seed={seedText}>Impuls kopieren</button>
          </div>
        </section>
      )
    }

    <section class="author-bio">
      <Image src={authorPhoto} alt="Jan Musiedlak" width={96} height={96} class="author-photo" />
      <p>
        Jan Musiedlak begleitet Geschäftsführer produzierender Unternehmen dabei, strategische Fragen zu
        strukturieren, Prioritäten abzuleiten und implizite Annahmen explizit zu machen — bevor Ressourcen
        gebunden werden.
      </p>
    </section>

    <p class="back"><a href="/">← Alle Beiträge</a></p>
  </article>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.seed-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.seed ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = 'Kopiert';
        btn.classList.add('is-copied');
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove('is-copied');
        }, 1800);
      } catch {
        btn.textContent = 'Kopieren nicht möglich';
      }
    });
  });
</script>
